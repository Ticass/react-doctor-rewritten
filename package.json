{
  "name": "react-doctor-rewritten",
  "version": "1.0.1",
  "private": true,
  "homepage": "https://github.com/Ticass/react-doctor#readme",
  "bugs": {
    "url": "https://github.com/Ticass/react-doctor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ticass/react-doctor.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter react-doctor-rewritten run dev",
    "build": "pnpm --filter react-doctor-rewritten run build",
    "test": "pnpm --filter react-doctor-rewritten run test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm --filter react-doctor-rewritten exec npm version patch --no-git-tag-version && pnpm build && pnpm --filter react-doctor-rewritten publish --access public --no-git-checks"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "knip": "^5.83.1",
    "picocolors": "^1.1.1",
    "pnpm": "^10.33.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.29.1"
}
